# ============================================================
# FOREXAI Terminal — Environment Variables
# Copy this file to .env.local for local dev.
# In production (Vercel): Settings → Environment Variables
# ============================================================

# ---- Twelve Data (forex/crypto candles 1h / 4h / daily) ----
# Required for Forex charts & candles
# Get key: https://twelvedata.com/account/api-keys
VITE_TWELVEDATA_API_KEY=

# ---- DeepSeek (strategy agents, news generation) ----
# Required for Signals page and News edition generation
# Get key: https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=

# ---- Anthropic / Claude (Vision, Logic Lab) ----
# Required for Vision page and Logic Lab debates
# Get key: https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=

# ---- Perplexity (Macro agent, news analysis) ----
# Required for News Macro analysis with web search
# Get key: https://www.perplexity.ai/settings/api
VITE_PERPLEXITY_API_KEY=

# ---- Kimi / Moonshot (Logic Lab arbitrator, Layer 3 sentiment) ----
# Get key: https://platform.moonshot.cn/console/api-keys
VITE_KIMI_API_KEY=

# ---- PRO Signals Backend (forexai-engine) ----
# Backend URL — do not change unless you self-host
VITE_FOREXAI_ENGINE_URL=https://yxc-3w62.vercel.app
# Shared secret — MUST match INTERNAL_API_KEY in the backend Vercel project
# Generate: openssl rand -hex 32
VITE_INTERNAL_API_KEY=

# -----------------------------------------------------------
# Public APIs (no key needed — listed for documentation)
# -----------------------------------------------------------
# /api/yahoo-chart   — Yahoo Finance v8 (proxied via Vercel fn)
# /api/yahoo-quote   — Yahoo Finance v7 (proxied via Vercel fn)
# open.er-api.com    — FX rates fallback 1
# fawazahmed0 CDN    — FX rates fallback 2
# Frankfurter ECB    — FX rates fallback 3
# Binance REST       — crypto candles (public)
# CoinGecko API      — crypto market data (public)
